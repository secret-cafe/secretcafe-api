generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model UserInfo {
  id          Int         @id @default(autoincrement()) @db.UnsignedInt
  roleId      Int?        @db.UnsignedInt
  name        String
  username    String      
  email       String      @db.VarChar(255)
  password    String      @db.VarChar(255)
  phoneNumber String?     @db.VarChar(20)
  isActive    Boolean     @default(true)
  createdBy   Int?        @db.UnsignedInt
  updatedBy   Int?        @db.UnsignedInt
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?
  role        Roles?      @relation(fields: [roleId], references: [id])

  @@index([deletedAt])
  @@index([roleId], map: "UserInfo_roleId_fkey")
}

model Roles {
  id          Int         @id @default(autoincrement()) @db.UnsignedInt
  name        String      @unique
  description String?     @db.VarChar(255)
  isActive    Boolean     @default(true)
  createdBy   Int?        @db.UnsignedInt
  updatedBy   Int?        @db.UnsignedInt
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?
  users       UserInfo[]

  @@index([deletedAt])
}

model Category {
  id          Int         @id @default(autoincrement()) @db.UnsignedInt
  name        String      @db.VarChar(255)
  description String?     @db.VarChar(5000)
  imageUrl    String?     @db.VarChar(500)
  isActive    Boolean     @default(true)
  createdBy   Int?        @db.UnsignedInt
  updatedBy   Int?        @db.UnsignedInt
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?

  // Relations
  menuItems   MenuItem[]

  @@index([deletedAt])
}

model MenuItem {
  id            Int           @id @default(autoincrement()) @db.UnsignedInt
  categoryId    Int           @db.UnsignedInt
  name          String        @db.VarChar(255)
  price         Decimal       @db.Decimal(10, 2)
  menuType      String        @db.VarChar(255)
  available     Boolean       @default(true)
  imageUrl      String?       @db.VarChar(500)
  description   String?       @db.VarChar(5000)
  createdBy     Int?          @db.UnsignedInt
  updatedBy     Int?          @db.UnsignedInt
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?

  // Relations
  category      Category      @relation(fields: [categoryId], references: [id], onUpdate: Cascade)
  subMenuItems  SubMenuItem[]

  @@index([deletedAt])
  @@index([categoryId])
}

model SubMenuItem {
  id          Int       @id @default(autoincrement()) @db.UnsignedInt
  menuId      Int       @db.UnsignedInt
  name        String    @db.VarChar(255)
  price       Decimal   @db.Decimal(10, 2)
  available   Boolean   @default(true)
  imageUrl    String?   @db.VarChar(500)
  description String?   @db.VarChar(5000)
  createdBy   Int?      @db.UnsignedInt
  updatedBy   Int?      @db.UnsignedInt
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  // Relations
  menuItem    MenuItem  @relation(fields: [menuId], references: [id], onUpdate: Cascade)

  @@index([deletedAt])
  @@index([menuId])
}